{
  "dashboard": {
    "title": "VPN Nodes Overview",
    "tags": ["nodes", "overview", "node-exporter"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "node",
          "type": "query",
          "query": "label_values(node_uname_info{job=\"node_exporter\"}, nodename)",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "multi": true,
          "includeAll": true,
          "current": { "selected": true, "text": "All", "value": "$__all" },
          "refresh": 2
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage %",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "100 - (avg by(nodename) (rate(node_cpu_seconds_total{mode=\"idle\",nodename=~\"$node\"}[5m])) * 100)",
            "legendFormat": "{{nodename}}",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]},
            "decimals": 1
          }
        },
        "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 2,
        "title": "RAM Usage %",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "(1 - node_memory_MemAvailable_bytes{nodename=~\"$node\"} / node_memory_MemTotal_bytes{nodename=~\"$node\"}) * 100",
            "legendFormat": "{{nodename}}",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]},
            "decimals": 1
          }
        },
        "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 3,
        "title": "Disk Usage %",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\",nodename=~\"$node\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\",nodename=~\"$node\"}) * 100",
            "legendFormat": "{{nodename}}",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]},
            "decimals": 1
          }
        },
        "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 4,
        "title": "Load Average (1m) per CPU",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "node_load1{nodename=~\"$node\"} / count without(cpu, mode) (node_cpu_seconds_total{mode=\"idle\",nodename=~\"$node\"})",
            "legendFormat": "{{nodename}}",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0, "max": 2,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "orange", "value": 1.0 },
              { "color": "red", "value": 1.5 }
            ]},
            "decimals": 2
          }
        },
        "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 5,
        "title": "Network Traffic IN (bytes/s)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total{device=~\"eth0|ens.*|enp.*\",nodename=~\"$node\"}[5m])",
            "legendFormat": "{{nodename}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "showPoints": "never" }
          }
        },
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 6,
        "title": "Network Traffic OUT (bytes/s)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "rate(node_network_transmit_bytes_total{device=~\"eth0|ens.*|enp.*\",nodename=~\"$node\"}[5m])",
            "legendFormat": "{{nodename}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "showPoints": "never" }
          }
        },
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 7,
        "title": "CPU Usage % Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "100 - (avg by(nodename) (rate(node_cpu_seconds_total{mode=\"idle\",nodename=~\"$node\"}[5m])) * 100)",
            "legendFormat": "{{nodename}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]}
          }
        },
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] } },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 8,
        "title": "RAM Usage % Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
        "targets": [
          {
            "expr": "(1 - node_memory_MemAvailable_bytes{nodename=~\"$node\"} / node_memory_MemTotal_bytes{nodename=~\"$node\"}) * 100",
            "legendFormat": "{{nodename}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0, "max": 100,
            "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 90 }
            ]}
          }
        },
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] } },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 9,
        "title": "Nodes Summary",
        "type": "table",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
        "targets": [
          {
            "expr": "100 - (avg by(nodename) (rate(node_cpu_seconds_total{mode=\"idle\",nodename=~\"$node\"}[5m])) * 100)",
            "legendFormat": "", "refId": "A", "format": "table", "instant": true
          },
          {
            "expr": "(1 - node_memory_MemAvailable_bytes{nodename=~\"$node\"} / node_memory_MemTotal_bytes{nodename=~\"$node\"}) * 100",
            "legendFormat": "", "refId": "B", "format": "table", "instant": true
          },
          {
            "expr": "node_memory_MemTotal_bytes{nodename=~\"$node\"}",
            "legendFormat": "", "refId": "C", "format": "table", "instant": true
          },
          {
            "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\",nodename=~\"$node\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\",nodename=~\"$node\"}) * 100",
            "legendFormat": "", "refId": "D", "format": "table", "instant": true
          },
          {
            "expr": "node_time_seconds{nodename=~\"$node\"} - node_boot_time_seconds{nodename=~\"$node\"}",
            "legendFormat": "", "refId": "E", "format": "table", "instant": true
          }
        ],
        "transformations": [
          { "id": "joinByField", "options": { "byField": "nodename", "mode": "outer" } },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true,
                "__name__": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true,
                "instance": true, "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true,
                "job": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true,
                "nodename 1": true, "nodename 2": true, "nodename 3": true, "nodename 4": true,
                "fstype": true, "mountpoint": true
              },
              "renameByName": {
                "nodename": "Node",
                "Value #A": "CPU %",
                "Value #B": "RAM %",
                "Value #C": "Total RAM",
                "Value #D": "Disk %",
                "Value #E": "Uptime"
              },
              "indexByName": {
                "nodename": 0,
                "Value #A": 1,
                "Value #B": 2,
                "Value #C": 3,
                "Value #D": 4,
                "Value #E": 5
              }
            }
          }
        ],
        "fieldConfig": {
          "defaults": {},
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "CPU %" },
              "properties": [
                { "id": "unit", "value": "percent" },
                { "id": "decimals", "value": 1 },
                { "id": "custom.cellOptions", "value": { "type": "color-background" } },
                { "id": "thresholds", "value": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 80}] } }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "RAM %" },
              "properties": [
                { "id": "unit", "value": "percent" },
                { "id": "decimals", "value": 1 },
                { "id": "custom.cellOptions", "value": { "type": "color-background" } },
                { "id": "thresholds", "value": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 90}] } }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Total RAM" },
              "properties": [
                { "id": "unit", "value": "bytes" },
                { "id": "decimals", "value": 1 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Disk %" },
              "properties": [
                { "id": "unit", "value": "percent" },
                { "id": "decimals", "value": 1 },
                { "id": "custom.cellOptions", "value": { "type": "color-background" } },
                { "id": "thresholds", "value": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}] } }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Uptime" },
              "properties": [
                { "id": "unit", "value": "s" },
                { "id": "decimals", "value": 0 }
              ]
            }
          ]
        },
        "options": { "sortBy": [{ "displayName": "CPU %", "desc": true }] },
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}
